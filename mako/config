default-timeout=10000
width=300
height=100
margin=10
padding=10
background-color=#1e1e1e
text-color=#ffffff
border-color=#ff0000
max-icon-size=48
icons=1
anchor=top-right
format=<b>%s</b>\n%b

[urgency=low]
background-color=#1e1e1e
text-color=#eeeeee
border-color=#ff0000

[urgency=normal]
background-color=#1e1e1e
text-color=#eeeeee
border-color=#ff0000

[urgency=critical]
background-color=#ff0000
text-color=#eeeeee
border-color=#eeeeee
